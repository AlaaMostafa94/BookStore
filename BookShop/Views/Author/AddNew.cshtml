@model BookShop.Models.Author
@{
    ViewBag.Title = "AddNew";
    Layout = "~/Views/Shared/_NewLayout.cshtml";

}

<br>
<br>

<h2 class="text-info">Add Author</h2>
<hr>

<div>
    <form action="/Author/addnew" method="post"  enctype="multipart/form-data" onsubmit="return isValid()">
        @Html.AntiForgeryToken()
        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
        <label>Name :</label>
        <div>
            <input type="text" name="name" id="authorName" class="form-control w-50" maxlength="30" />
            @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger", id = "nameErrorMsg" })
        </div><br>
        <label>About :</label>
        <div>
            <input type="text" name="about" id="aboutAuthor" class="form-control w-50" maxlength="500" />
            @Html.ValidationMessageFor(model => model.About, "", new { @class = "text-danger", id = "aboutErrorMsg" })
        </div><br>
        <label>Image :</label>
        <div>
            <input type="file" name="file" id="file" />
            @Html.ValidationMessageFor(model => model.ImagePath, "", new { @class = "text-danger", id = "imgErrorMsg" })

        </div><br>

        <input type="submit" value="Save" class="btn btn-info" />

    </form>
</div>
<hr />
<div>

    <button onclick="window.history.back()" class="btn btn-info" title="Back"><i class="fa fa-arrow-left"></i></button>
</div>
<script>
    function isValid() {
        var authorName = document.getElementById("authorName").value;
        var aboutAuthor = document.getElementById("aboutAuthor").value;
        var nameValid = false;
        var aboutValid = false;
        if (authorName.trim() == "") {
            document.getElementById("nameErrorMsg").innerHTML = "Author name can not be empty .";
            nameValid = false;
        }
        else if (authorName.trim().length < 3) {
            document.getElementById("nameErrorMsg").innerHTML = "Author name must be at least 3 characters .";
            nameValid = false;
        }
        else {
            document.getElementById("ErrorMsg").innerHTML = "";
            nameValid = true;
        }

        if (aboutAuthor.trim() == "") {
            document.getElementById("aboutErrorMsg").innerHTML = "The field 'About' can not be empty .";
            aboutValid = false;
        }
        else if (aboutAuthor.trim().length < 20) {
            document.getElementById("aboutErrorMsg").innerHTML = "Text must be at least 20 characters .";
            aboutValid = false;
        }
        else {
            document.getElementById("aboutErrorMsg").innerHTML = "";
            aboutValid = true;
        }

        return nameValid && aboutValid;
    }
</script>