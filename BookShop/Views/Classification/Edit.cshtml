@model BookShop.Models.Classification

@{
    ViewBag.Title = "Edit";
    Layout = "~/Views/Shared/_NewLayout.cshtml";

}
<br><br>
<h2 class="text-info">Edit classification</h2>
<hr>
<div>
    <form method="post" action="/classification/edit/@Model.ID" onsubmit="return isValid()">
        @Html.AntiForgeryToken()

        <div class="form-horizontal">


            @Html.ValidationSummary(true, "", new { @class = "text-danger" })
            @Html.HiddenFor(model => model.ID)


            @Html.LabelFor(model => model.Name)
            <div>
                <input type="text" name="name" id="classificationName" class="form-control w-50" maxlength="20" value="@Model.Name" />
                @Html.ValidationMessageFor(model => model.Name, "", new { @class = "text-danger", id = "ErrorMsg" })
            </div><br>


            <div class="form-group">
                <div class="col-md-offset-2 col-md-10">
                    <input type="submit" value="Save" class="btn btn-info" />
                </div>
            </div>
        </div>
    </form>
</div>
<hr>
<div>

    <button onclick="window.history.back()" class="btn btn-info" title="Back"><i class="fa fa-arrow-left"></i></button>
</div>
<script>
    function isValid() {
        var classificationName = document.getElementById("classificationName").value;
        if (classificationName.trim() == "") {
            document.getElementById("ErrorMsg").innerHTML = "Classification name can not be empty .";
            //console.log("Classification name can not be empty .");
            return false;
        }
        else if (classificationName.trim().length < 3) {
            document.getElementById("ErrorMsg").innerHTML = "Classification name must be at least 3 characters .";
            //console.log("Classification name must be at least 3 characters .")
            return false;
        }
        else {
            document.getElementById("ErrorMsg").innerHTML = "";
            return true;
        }
    }
</script>
